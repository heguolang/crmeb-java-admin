# 开发环境（复制为 .env.development 后按本机修改，勿提交 .env.development）
# 使用：npm run dev（Vue CLI mode = development）

# 后端 HTTP 根地址（不要带末尾 /api/；代码里会拼接 /api/）
VUE_APP_BASE_API=http://127.0.0.1:8080

# WebSocket 地址（与后端一致；HTTPS 页面请用 wss://）
VUE_APP_WS_URL=ws://127.0.0.1:8080

# 可选：当前构建环境标识（业务代码可读 process.env.VUE_APP_ENV）
VUE_APP_ENV=development
